          "full_name",
          "owner",
          "is_private"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "full_name": {
            "type": "string"
          },
          "owner": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "default_branch": {
            "type": "string"
          },
          "html_url": {
            "type": "string"
          },
          "is_private": {
            "type": "boolean"
          }
        }
      },
      "IssuePage": {
        "type": "object",
        "required": [
          "items",
          "page",
          "page_size",
          "total"
