      "Issue": {
        "type": "object",
        "required": [
          "id",
          "repository_id",
          "number",
          "title",
          "state"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "repository_id": {
            "type": "string"
          },
          "number": {
            "type": "integer"
          },
          "title": {
            "type": "string"
          },
          "state": {
            "type": "string"
          },
          "html_url": {
            "type": "string"
          }
