SDKWORK_GITHUB_HOSTING=self-hosted
SDKWORK_GITHUB_SERVICE_LAYOUT=unified-process
SDKWORK_GITHUB_ENVIRONMENT=development
SDKWORK_GITHUB_PROFILE_ID=self-hosted.unified-process.development
SDKWORK_GITHUB_APPLICATION_PUBLIC_INGRESS_BIND=127.0.0.1:4100
SDKWORK_GITHUB_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:4100
VITE_SDKWORK_GITHUB_APPLICATION_PUBLIC_HTTP_URL=http://127.0.0.1:4100
SDKWORK_GITHUB_DATABASE_ENGINE=sqlite
SDKWORK_GITHUB_DATABASE_URL=sqlite:./.data/github/dev.sqlite
SDKWORK_GITHUB_DATABASE_SEED_ON_BOOT=true
SDKWORK_GITHUB_DATABASE_SEED_LOCALE=zh-CN
SDKWORK_GITHUB_DATABASE_SEED_PROFILE=standard
# Encrypt tenant-linked GitHub tokens at rest (derive AES-256 key via SHA-256).
SDKWORK_GITHUB_CREDENTIAL_ENCRYPTION_KEY=dev-github-credential-key-change-me
# Optional dev fallback when tenant integration is not linked yet.
# SDKWORK_GITHUB_INTEGRATION_PAT=
# SDKWORK_GITHUB_INTEGRATION_API_BASE=https://api.github.com
# GitHub OAuth (register app redirect to /app/v3/api/github/integration/oauth/callback)
# SDKWORK_GITHUB_OAUTH_CLIENT_ID=
# SDKWORK_GITHUB_OAUTH_CLIENT_SECRET=
SDKWORK_GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:4100/app/v3/api/github/integration/oauth/callback
SDKWORK_GITHUB_OAUTH_SUCCESS_REDIRECT_URL=http://127.0.0.1:5175/integration
# SDKWORK_GITHUB_OAUTH_SCOPES=read:user,repo
