    {
      "method": "POST",
      "path": "/app/v3/api/github/integration",
      "operationId": "integration.link",
      "domain": "github",
      "authMode": "dual-token",
      "requestContext": "WebRequestContext",
      "apiSurface": "app-api"
    },
    {
      "method": "DELETE",
      "path": "/app/v3/api/github/integration",
      "operationId": "integration.unlink",
      "domain": "github",
      "authMode": "dual-token",
      "requestContext": "WebRequestContext",
      "apiSurface": "app-api"
