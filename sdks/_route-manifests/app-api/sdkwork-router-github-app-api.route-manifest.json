      "authMode": "dual-token",
      "requestContext": "WebRequestContext",
      "apiSurface": "app-api"
    },
    {
      "method": "POST",
      "path": "/app/v3/api/github/repositories/sync",
      "operationId": "repositories.sync",
      "domain": "github",
      "authMode": "dual-token",
      "requestContext": "WebRequestContext",
      "apiSurface": "app-api"
    },
    {
      "method": "GET",
      "path": "/app/v3/api/github/issues",
      "operationId": "issues.list",
      "domain": "github",
      "authMode": "dual-token",
      "requestContext": "WebRequestContext",
      "apiSurface": "app-api"
    },
    {
      "method": "POST",
      "path": "/app/v3/api/github/issues/sync",
      "operationId": "issues.sync",
      "domain": "github",
      "authMode": "dual-token",
      "requestContext": "WebRequestContext",
