{
  "schemaVersion": 3,
  "kind": "sdkwork.app",
  "app": {
    "key": "sdkwork-github",
    "name": "SDKWork GitHub",
    "displayName": "SDKWork GitHub",
    "description": "GitHub integration for repositories, issues, and planning.",
    "vendor": "SDKWork",
    "officialWebsiteUrl": "https://sdkwork.com/apps/sdkwork-github",
    "appType": "APP_REACT",
    "versionSource": "package.json"
  },
  "backend": {
    "profileKey": "backend-root-admin",
    "ownerMode": "tenant",
    "grantMode": "current",
    "platform": "WEB",
    "appId": "sdkwork-github-pc",
    "tenantId": "100001",
    "organizationId": "0",
    "accessTokenPermissionScope": [
      "iam.users.read",
      "iam.organizations.read",
      "iam.roles.read",
      "iam.permissions.read"
    ]
  },
  "runtime": {
    "family": "browser",
    "framework": "react",
    "runtimes": ["WEB"],
    "deliveryModes": ["WEB_URL"],
    "supportedDeploymentProfiles": ["standalone", "cloud"],
    "defaultDeploymentProfile": "standalone"
  },
  "sdkDependencies": [
    { "sdkFamily": "sdkwork-iam-app-sdk", "surface": "app-api", "owner": "sdkwork-appbase" },
    { "sdkFamily": "sdkwork-github-app-sdk", "surface": "app-api", "owner": "sdkwork-github" }
  ],
  "dependencyApiExports": [],
  "dependencyApiSurfaces": [
    { "sdkFamily": "sdkwork-iam-app-sdk", "surface": "app-api", "runtimeMode": "embedded-or-split" }
  ]
}
