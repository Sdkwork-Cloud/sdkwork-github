{
  "schemaVersion": 2,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-github",
  "archetype": "application-http-gateway",
  "profileRoot": "configs/topology",
  "profilePattern": "{hosting}.{serviceLayout}.{environment}.env",
  "vocabulary": {
    "hosting": { "allowed": ["self-hosted", "cloud-hosted"] },
    "serviceLayout": { "allowed": ["unified-process", "split-services"] },
    "environment": { "allowed": ["development", "production"] }
  },
  "defaults": {
    "developmentProfileId": "self-hosted.unified-process.development",
    "productionProfileId": "cloud-hosted.split-services.production",
    "gatewayBind": "127.0.0.1:4100"
  },
  "profileFiles": {
    "self-hosted.unified-process.development": "configs/topology/self-hosted.unified-process.development.env"
  },
  "envKeys": {
    "hosting": "SDKWORK_GITHUB_HOSTING",
    "serviceLayout": "SDKWORK_GITHUB_SERVICE_LAYOUT",
    "environment": "SDKWORK_GITHUB_ENVIRONMENT",
    "profileId": "SDKWORK_GITHUB_PROFILE_ID",
    "standaloneGatewayBind": "SDKWORK_GITHUB_APPLICATION_PUBLIC_INGRESS_BIND"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": ["http"],
      "bindEnv": "SDKWORK_GITHUB_APPLICATION_PUBLIC_INGRESS_BIND",
      "httpUrlEnv": "SDKWORK_GITHUB_APPLICATION_PUBLIC_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_GITHUB_APPLICATION_PUBLIC_HTTP_URL"
    }
  },
  "database": {
    "appPrefix": "SDKWORK_GITHUB"
  },
  "components": {
    "applicationServer": {
      "crate": "sdkwork-github-api-server",
      "binary": "sdkwork-github-api-server"
    }
  }
}
